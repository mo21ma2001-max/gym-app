<%- include('./partials/header') %>

<div class="text-center mb-5">
  <h1 class="fw-bold">Contact Us <i class="bi bi-envelope-fill text-danger"></i></h1>
  <div class="section-divider"></div>
  <p style="color:#ccc;">We'd love to hear from you!</p>
</div>

<div class="row justify-content-center g-4">
  <div class="col-md-4">
    <div class="card p-4 text-center h-100">
      <i class="bi bi-telephone-fill text-danger fs-2 mb-3"></i>
      <h5 class="fw-bold">Phone</h5>
      <p style="color:#aaa;" class="mb-0"><%= phone %></p>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card p-4 text-center h-100">
      <i class="bi bi-envelope-at-fill text-danger fs-2 mb-3"></i>
      <h5 class="fw-bold">Email</h5>
      <p style="color:#aaa;" class="mb-0"><%= email %></p>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card p-4 text-center h-100">
      <i class="bi bi-geo-alt-fill text-danger fs-2 mb-3"></i>
      <h5 class="fw-bold">Location</h5>
      <p style="color:#aaa;" class="mb-0"><%= location %></p>
    </div>
  </div>
</div>

<%- include('./partials/footer') %>
