<%- include('./partials/header') %>

<div class="d-flex flex-column align-items-center justify-content-center text-center" style="min-height:65vh;">

  <!-- Animated icon -->
  <div style="position:relative; display:inline-block;">
    <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size:5rem; filter: drop-shadow(0 0 20px rgba(220,53,69,0.6));"></i>
  </div>

  <!-- 404 Number -->
  <h1 class="fw-bold mt-2" style="font-size:9rem; line-height:1; color:#dc3545;
      text-shadow: 0 0 60px rgba(220,53,69,0.35), 0 0 120px rgba(220,53,69,0.15);">
    404
  </h1>

  <h2 class="fw-bold mb-2">Page Not Found</h2>
  <p style="color:#aaa; font-size:1.05rem; max-width:420px;">
    Looks like you wandered off the track! 🏃<br />
    This page doesn't exist or has been moved.
  </p>

  <!-- Action buttons -->
  <div class="d-flex gap-3 mt-3 flex-wrap justify-content-center">
    <a href="/" class="btn btn-danger btn-lg px-5">
      <i class="bi bi-house-fill me-2"></i>Back to Home
    </a>
    <a href="/features" class="btn btn-outline-danger btn-lg px-4">
      <i class="bi bi-grid me-2"></i>Our Features
    </a>
  </div>

  <!-- Quick links -->
  <div class="mt-4 d-flex gap-3 flex-wrap justify-content-center">
    <a href="/about"   style="color:#aaa;" class="text-decoration-none small"><i class="bi bi-info-circle me-1"></i>About</a>
    <a href="/contact" style="color:#aaa;" class="text-decoration-none small"><i class="bi bi-envelope me-1"></i>Contact</a>
    <a href="/items"   style="color:#aaa;" class="text-decoration-none small"><i class="bi bi-dumbbell me-1"></i>Equipment</a>
  </div>
</div>

<%- include('./partials/footer') %>
